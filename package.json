{
  "name": "@aquarium-tools/shoal",
  "version": "0.2.0",
  "private": true,
  "description": "Jira and GitHub Issues MCP server — correct, complete, open source",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "shoal": "dist/index.js",
    "shoal-jira": "dist/index-jira.js",
    "shoal-github": "dist/index-github.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:jira": "tsx src/index-jira.ts",
    "dev:github": "tsx src/index-github.ts",
    "start": "node dist/index.js",
    "start:jira": "node dist/index-jira.js",
    "start:github": "node dist/index-github.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "keywords": ["mcp", "jira", "atlassian", "github", "issues", "model-context-protocol"],
  "engines": {
    "node": ">=22"
  },
  "license": "Apache-2.0"
}
