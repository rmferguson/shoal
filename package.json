{
  "name": "@aquarium-tools/shoal",
  "version": "0.2.0",
  "description": "Jira MCP server — correct, complete, open source",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "shoal": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rmferguson/shoal.git"
  },
  "homepage": "https://github.com/rmferguson/shoal#readme",
  "bugs": "https://github.com/rmferguson/shoal/issues",
  "author": "Robert Ferguson",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "rm -rf dist && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "keywords": ["mcp", "jira", "atlassian", "model-context-protocol"],
  "engines": {
    "node": ">=22"
  },
  "license": "Apache-2.0"
}
